# IBKR connection (TWS or IB Gateway must be running locally with API enabled)
# TWS paper:    7497    TWS live:    7496
# Gateway paper:4002    Gateway live:4001
IBKR_HOST=127.0.0.1
IBKR_PORT=7497
IBKR_CLIENT_ID=42

# DuckDB path (relative to repo root)
CHAIN_PEEPER_DB=data/chain_peeper.duckdb

# Default request timeout for market data, seconds
IBKR_MKTDATA_TIMEOUT=8
